{% extends 'base.html.twig' %}

{% block body %}

<div id="form-modif">
{{ form_start(form) }}

<div class="row">
    <div class="col">
        {{ form_row(form.nom) }}
    </div>
    <div class="col">
        {{ form_row(form.prenom) }}
    </div>
</div>

<div class="row">
    <div class="col">
        {{ form_row(form.email) }}
    </div>
    <div class="col">
        {{ form_row(form.username) }}
    </div>
</div>

<div class="row">
    <div class="col">
        {{ form_row(form.ville) }}
    </div>
    <div class="col">
        {{ form_row(form.code_postal) }}
    </div>
</div>

<div class="full">
    {{ form_row(form.add_livraison) }}
</div>

<div class="row">
    <div class="col">
        {{ form_row(form.portable) }}
    </div>
</div>

<button type="submit">Salva</button>

{{ form_end(form) }}
</div>

{% endblock %}