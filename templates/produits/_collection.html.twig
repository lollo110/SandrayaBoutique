<div class="collection">
    <i class="fa-solid fa-chevron-left freccia3"></i>

    <div class="carte-container">
        {% for produit in produits %}
            {% if produit.category == category %}
                <div class="carte">
                    
                    <div class="img">
                    <div class="actions">
                    <i class="fa-solid fa-plus addToCart" id="{{ produit.id }}"></i>
                    <i class="{{ produit.id in favorisIds ? 'fa-solid' : 'fa-regular' }} fa-star favoris" id="{{ produit.id }}"></i>
                    </div>
                        {% for produitImage in produit.produitsImages|slice(0, 1) %}

                            <div class="cornice-wrapper">
                            <a href="{{ path('app_detail_produit', {'id': produit.id}) }}">
                            <img src="{{ asset('assets/uploads/cornice-rune.png') }}" class="cornice" alt="cornice" />
                            </a>
                            <div class="text">
                                <h3>{{ produit.nomProd }}</h3>
                                <p>{{ produit.prix }} €</p>
                                {% if produit.noteMoyenne %}
    {% set note = produit.noteMoyenne|round(0, 'floor') %}
    {% for i in 1..5 %}
        {% if i <= note %}
            ★
        {% else %}
            ☆
        {% endif %}
    {% endfor %}
    ({{ produit.noteMoyenne }})
{% endif %}
                            </div>
                            </div>

                            <a href="{{ path('app_detail_produit', {'id': produit.id}) }}">
                                <img src="{{ asset('assets/uploads/' ~ produitImage.image) }}"
                                     alt="Image de {{ produit.nomProd }}"
                                     class="produitImage"/>
                            </a>
                        {% endfor %}
                    </div>
                </div>
            {% endif %}
        {% endfor %}
    </div>

    <i class="fa-solid fa-chevron-right freccia4"></i>
</div>
